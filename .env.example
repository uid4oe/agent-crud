# Database
DATABASE_URL=postgres://postgres:postgres@localhost:5432/agent_crud

# Gemini AI
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-2.5-flash-lite
GEMINI_ROUTER_MODEL=gemini-2.5-flash

# Server
PORT=3000

# Langfuse (LLM Observability — optional)
# Get keys from Langfuse UI: http://localhost:3001 -> Settings -> Create API Keys
LANGFUSE_SECRET_KEY=
LANGFUSE_PUBLIC_KEY=
LANGFUSE_BASE_URL=http://localhost:3001
