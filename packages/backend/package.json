{
  "name": "backend",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "main": "./dist/main.js",
  "types": "./dist/main.d.ts",
  "exports": {
    ".": {
      "types": "./dist/main.d.ts",
      "import": "./dist/main.js"
    }
  },
  "scripts": {
    "dev": "tsx watch src/main.ts",
    "build": "tsc",
    "start": "node dist/main.js",
    "start:migrate": "node dist/infrastructure/adapters/persistence/drizzle/migrate.js && node dist/main.js",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "tsx src/infrastructure/adapters/persistence/drizzle/migrate.ts",
    "db:migrate:prod": "node dist/infrastructure/adapters/persistence/drizzle/migrate.js",
    "db:push": "drizzle-kit push --force",
    "db:reset": "tsx src/infrastructure/adapters/persistence/drizzle/reset.ts",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@google/adk": "^0.3.0",
    "@google/genai": "^1.37.0",
    "@trpc/server": "^11.0.0-rc.532",
    "cors": "^2.8.5",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.33.0",
    "express": "^4.21.0",
    "langfuse": "^3.38.6",
    "postgres": "^3.4.4",
    "ws": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.5",
    "@types/ws": "^8.18.1",
    "drizzle-kit": "^0.24.2",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2",
    "vitest": "^4.0.18"
  }
}
